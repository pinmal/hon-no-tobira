---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '本のとびら — Kindleで読める本を毎日紹介します' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://hon-no-tobira.pages.dev').href;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="2XwvgRkgr4z2rlBI9kVlkHlgWPMuUpzMdpYCqOAEO4Q" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-J66K1P5TRK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J66K1P5TRK');
    </script>
  </head>
  <body class="bg-bg text-textPrimary font-sans min-h-screen">
    <header class="sticky top-0 z-10 bg-bg/90 backdrop-blur border-b border-border">
      <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-2xl">📖</span>
          <span class="text-lg font-bold text-accent group-hover:text-accentLight transition-colors">本のとびら</span>
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/" class="text-textMuted hover:text-textPrimary transition-colors">書籍一覧</a>
          <a href="/request" class="bg-accent text-bg px-3 py-1.5 rounded-lg font-bold hover:bg-accentLight transition-colors text-xs">
            宣伝依頼
          </a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-border mt-16">
      <div class="max-w-4xl mx-auto px-4 py-8 text-center text-xs text-textMuted space-y-1">
        <p>© 2026 本のとびら</p>
        <p>本サイトはAmazonアソシエイト・プログラムの参加者です。</p>
        <p>紹介書籍の著者はすべて架空のキャラクターです（内容は実際の調査に基づきます）。</p>
        <div class="border-t border-border pt-4 mt-4">
          <p class="mb-2 font-medium">関連サイト</p>
          <div class="flex flex-wrap justify-center gap-x-4 gap-y-1">
            <a href="https://tsuriyoho.com" target="_blank" rel="noopener" class="hover:underline">つりナビ — 釣り予報アドバイザー</a>
            <a href="https://tsuri-camp.com" target="_blank" rel="noopener" class="hover:underline">やまちゃんの釣りキャンプ日記</a>
            <a href="https://jitan-kenko.blog" target="_blank" rel="noopener" class="hover:underline">時短 × 健康ブログ</a>
            <a href="https://drnagatomo2026.com" target="_blank" rel="noopener" class="hover:underline">精神科医ながともの処方箋ブログ</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
