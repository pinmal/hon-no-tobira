---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '本のとびら — Kindleで読める本を毎日紹介します' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://hon-no-tobira.pages.dev').href;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="2XwvgRkgr4z2rlBI9kVlkHlgWPMuUpzMdpYCqOAEO4Q" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="本のとびら RSS" href="https://hon-no-tobira.pages.dev/rss.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://hon-no-tobira.pages.dev/covers/book01.jpg" />
    <meta property="og:image:width" content="200" />
    <meta property="og:image:height" content="300" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://hon-no-tobira.pages.dev/covers/book01.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-J66K1P5TRK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J66K1P5TRK');
    </script>
  </head>
  <body class="bg-bg text-textPrimary font-sans min-h-screen">
    <header class="sticky top-0 z-10 bg-bg/90 backdrop-blur border-b border-border">
      <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-2xl">📖</span>
          <span class="text-lg font-bold text-accent group-hover:text-accentLight transition-colors">本のとびら</span>
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/" class="text-textMuted hover:text-textPrimary transition-colors">書籍一覧</a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-border mt-16">
      <div class="max-w-4xl mx-auto px-4 py-8 text-center text-xs text-textMuted space-y-1">
        <p>© 2026 本のとびら</p>
        <p>本サイトはAmazonアソシエイト・プログラムの参加者です。</p>
      </div>
    </footer>
  <!-- affiliate_click auto-tracker -->
  <script is:inline>
  (function(){document.addEventListener('click',function(e){var a=e.target.closest('a');if(!a)return;var h=a.href||'';var s=null;if(h.indexOf('amazon.co.jp')!==-1)s='amazon';else if(h.indexOf('afl.rakuten.co.jp')!==-1||h.indexOf('search.rakuten.co.jp')!==-1)s='rakuten';else if(h.indexOf('naturum.co.jp')!==-1)s='naturum';else if(h.indexOf('af.moshimo.com')!==-1)s='moshimo';else if(h.indexOf('px.a8.net')!==-1){try{var ar=new URL(h).searchParams.get('a8ejpredirect');s=ar&&new URL(decodeURIComponent(ar)).hostname.indexOf('naturum.co.jp')!==-1?'naturum':'a8';}catch(e2){s='a8';}}if(!s)return;var l='unknown';try{var u=new URL(h);var k=u.searchParams.get('k')||u.searchParams.get('keyword');if(k){l=decodeURIComponent(k).slice(0,60);}else{var m=u.pathname.match(/\/dp\/([A-Z0-9]{10})/);if(m)l='ASIN:'+m[1];var r=u.searchParams.get('a8ejpredirect');if(r){try{var i=new URL(decodeURIComponent(r));var nk=i.searchParams.get('keyword')||i.searchParams.get('k');if(nk)l=decodeURIComponent(nk).slice(0,60);}catch(e2){}}var pc=u.searchParams.get('pc');if(pc){try{var iu=new URL(decodeURIComponent(pc));var sg=iu.pathname.split('/').filter(Boolean);var ix=sg.indexOf('mall');if(ix>=0&&sg[ix+1])l=decodeURIComponent(sg[ix+1]).slice(0,60);}catch(e2){}}}}catch(e){}if(typeof window.gtag==='function')window.gtag('event','affiliate_click',{store:s,item_label:l,page_path:window.location.pathname});},{passive:true});})();
  </script>
  </body>
</html>
