---
import Layout from '../components/Layout.astro';
---

<Layout
  title="宣伝依頼 — 本のとびら"
  description="Kindle本の宣伝依頼はこちら。Instagram @hon_no_tobira でフォロワーへ紹介します。"
>
  <div class="max-w-2xl mx-auto space-y-10">

    <!-- Hero -->
    <section class="text-center space-y-3 py-6">
      <div class="text-4xl">✉️</div>
      <h1 class="text-2xl font-bold">宣伝依頼について</h1>
      <p class="text-textMuted text-sm leading-relaxed">
        Instagram <strong class="text-textPrimary">@hon_no_tobira</strong> でKindle本を紹介します。<br />
        依頼はDMにてお気軽にご連絡ください。
      </p>
    </section>

    <!-- What we do -->
    <section class="bg-surface rounded-2xl p-6 border border-border space-y-4">
      <h2 class="font-bold text-accent text-lg">紹介内容</h2>
      <ul class="space-y-3 text-sm text-textMuted">
        <li class="flex gap-3">
          <span class="text-accent mt-0.5">✓</span>
          <span>表紙画像＋書籍情報をInstagramに投稿</span>
        </li>
        <li class="flex gap-3">
          <span class="text-accent mt-0.5">✓</span>
          <span>ジャンル・読者層に合わせたキャプション文作成</span>
        </li>
        <li class="flex gap-3">
          <span class="text-accent mt-0.5">✓</span>
          <span>本サイト「書籍一覧」ページへの掲載（希望の場合）</span>
        </li>
        <li class="flex gap-3">
          <span class="text-accent mt-0.5">✓</span>
          <span>ハッシュタグ選定・投稿スケジュール調整</span>
        </li>
      </ul>
    </section>

    <!-- Fee -->
    <section class="bg-surface rounded-2xl p-6 border border-border space-y-4">
      <h2 class="font-bold text-accent text-lg">依頼料について</h2>
      <p class="text-sm text-textPrimary">依頼内容によって変わります。まずはDMにてお気軽にご相談ください。</p>
    </section>

    <!-- How to apply -->
    <section class="bg-surface rounded-2xl p-6 border border-border space-y-4">
      <h2 class="font-bold text-accent text-lg">依頼の流れ</h2>
      <ol class="space-y-4 text-sm">
        <li class="flex gap-4">
          <span class="shrink-0 w-6 h-6 rounded-full bg-accent text-bg text-xs font-bold flex items-center justify-center">1</span>
          <div>
            <p class="text-textPrimary font-medium">InstagramのDMへご連絡</p>
            <p class="text-textMuted text-xs mt-0.5">書籍タイトル・AmazonURL・希望投稿数をお知らせください。</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-6 h-6 rounded-full bg-accent text-bg text-xs font-bold flex items-center justify-center">2</span>
          <div>
            <p class="text-textPrimary font-medium">内容確認・お見積り</p>
            <p class="text-textMuted text-xs mt-0.5">内容・料金・スケジュールをDMで調整します。</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-6 h-6 rounded-full bg-accent text-bg text-xs font-bold flex items-center justify-center">3</span>
          <div>
            <p class="text-textPrimary font-medium">投稿・完了報告</p>
            <p class="text-textMuted text-xs mt-0.5">投稿後にURLをDMでお送りします。</p>
          </div>
        </li>
      </ol>
    </section>

    <!-- CTA -->
    <section class="text-center space-y-4 pb-6">
      <p class="text-textMuted text-sm">まずはお気軽にDMください。</p>
      <a
        href="https://www.instagram.com/hon_no_tobira"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-pink-500 text-white text-sm font-bold px-6 py-3 rounded-full hover:opacity-90 transition-opacity"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @hon_no_tobira にDMする
      </a>
    </section>

  </div>
</Layout>
