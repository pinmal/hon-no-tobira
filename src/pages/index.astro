---
import Layout from '../components/Layout.astro';
import BookCard from '../components/BookCard.astro';
import { books, genres } from '../data/books';
---

<Layout title="本のとびら — Kindleおすすめ書籍一覧">
  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "本のとびら Kindle書籍一覧",
    "description": "Kindleで読める本を毎日紹介しています。釣り・キャンプ・料理・健康・犬・園芸 ジャンル多彩。",
    "url": "https://hon-no-tobira.pages.dev/",
    "numberOfItems": books.length,
    "itemListElement": books.map((book, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Book",
        "name": book.title,
        "author": { "@type": "Person", "name": book.author },
        "genre": book.genre,
        "image": `https://hon-no-tobira.pages.dev${book.cover}`,
        ...(book.asin ? { "url": `https://www.amazon.co.jp/dp/${book.asin}?tag=honnotobira-22` } : {}),
        ...(book.price ? { "offers": { "@type": "Offer", "price": book.price, "priceCurrency": "JPY" } } : {}),
      }
    }))
  })} />
  <!-- Hero -->
  <section class="text-center py-8 space-y-3">
    <div class="text-5xl">📖</div>
    <h1 class="text-2xl font-bold text-textPrimary">本のとびら</h1>
    <p class="text-textMuted text-sm max-w-md mx-auto leading-relaxed">
      Kindleで読める本を毎日紹介しています。<br />
      釣り・キャンプ・料理・健康・犬・園芸 ジャンル多彩。
    </p>
    <a
      href="https://www.instagram.com/honno_tobira"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-pink-500 text-white text-sm font-bold px-5 py-2.5 rounded-full hover:opacity-90 transition-opacity"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
      @honno_tobira をフォロー
    </a>
  </section>

  <!-- Genre filter -->
  <section class="mb-6">
    <div class="flex flex-wrap gap-2 justify-center" id="genre-filter">
      <button
        data-genre="all"
        class="genre-btn active text-xs px-3 py-1.5 rounded-full border border-accent bg-accent text-bg font-bold transition-colors"
      >
        すべて
      </button>
      {genres.map((genre) => (
        <button
          data-genre={genre}
          class="genre-btn text-xs px-3 py-1.5 rounded-full border border-border text-textMuted hover:border-accent hover:text-textPrimary transition-colors"
        >
          {genre}
        </button>
      ))}
    </div>
  </section>

  <!-- Book grid -->
  <section>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4" id="book-grid">
      {books.map((book) => (
        <div data-genre={book.genre} class="book-item">
          <BookCard book={book} />
        </div>
      ))}
    </div>
    <p id="no-results" class="hidden text-center text-textMuted text-sm py-12">
      このジャンルの書籍は準備中です。
    </p>
  </section>

  <!-- Book detail modal -->
  <div id="book-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative z-10 bg-card border border-border rounded-2xl max-w-lg w-full max-h-[85vh] overflow-y-auto shadow-2xl">
      <!-- Close button -->
      <button
        id="modal-close"
        class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-textMuted hover:text-textPrimary text-lg font-bold rounded-full hover:bg-surface transition-colors"
        aria-label="閉じる"
      >×</button>

      <!-- Header -->
      <div class="flex gap-4 p-5 border-b border-border pr-12">
        <img id="modal-cover" src="" alt="" class="w-16 h-24 object-cover rounded-lg flex-shrink-0 border border-border" />
        <div class="flex-1 min-w-0">
          <span id="modal-genre" class="text-xs px-2 py-0.5 rounded-full font-medium"></span>
          <h2 id="modal-title" class="text-sm font-bold text-textPrimary mt-2 leading-snug"></h2>
          <p id="modal-author" class="text-xs text-textMuted mt-1"></p>
        </div>
      </div>

      <!-- Body -->
      <div class="p-5 space-y-5">
        <!-- TOC -->
        <div>
          <h3 class="text-xs font-bold text-accent tracking-wide mb-3">📋 目次</h3>
          <ol id="modal-toc" class="space-y-2"></ol>
        </div>

        <!-- Excerpt -->
        <div>
          <h3 class="text-xs font-bold text-accent tracking-wide mb-3">📖 冒頭試し読み</h3>
          <p id="modal-excerpt" class="text-sm text-textPrimary leading-relaxed"></p>
          <p class="text-xs text-textMuted mt-3">……（続きはAmazonで）</p>
        </div>

        <!-- Amazon button -->
        <a
          id="modal-amazon"
          href="#"
          target="_blank"
          rel="sponsored noopener noreferrer"
          class="block w-full text-center text-sm font-bold py-3 px-4 rounded-lg bg-accent text-bg hover:bg-accentLight transition-colors"
        >
          Amazonで読む →
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  // === Genre filter ===
  const buttons = document.querySelectorAll<HTMLButtonElement>('.genre-btn');
  const items = document.querySelectorAll<HTMLElement>('.book-item');
  const noResults = document.getElementById('no-results')!;

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const genre = btn.dataset.genre!;

      buttons.forEach((b) => {
        b.classList.remove('active', 'bg-accent', 'text-bg', 'border-accent');
        b.classList.add('border-border', 'text-textMuted');
      });
      btn.classList.add('active', 'bg-accent', 'text-bg', 'border-accent');
      btn.classList.remove('border-border', 'text-textMuted');

      let visible = 0;
      items.forEach((item) => {
        if (genre === 'all' || item.dataset.genre === genre) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      noResults.classList.toggle('hidden', visible > 0);
    });
  });

  // === Book detail modal ===
  const modal = document.getElementById('book-modal')!;
  const modalBackdrop = document.getElementById('modal-backdrop')!;
  const modalClose = document.getElementById('modal-close')!;
  const modalCover = document.getElementById('modal-cover') as HTMLImageElement;
  const modalGenre = document.getElementById('modal-genre')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalAuthor = document.getElementById('modal-author')!;
  const modalToc = document.getElementById('modal-toc')!;
  const modalExcerpt = document.getElementById('modal-excerpt')!;
  const modalAmazon = document.getElementById('modal-amazon') as HTMLAnchorElement;

  const GENRE_COLOR: Record<string, string> = {
    '釣り': 'bg-blue-900 text-blue-200',
    'キャンプ': 'bg-green-900 text-green-200',
    '料理': 'bg-orange-900 text-orange-200',
    '健康・生活': 'bg-purple-900 text-purple-200',
    '犬': 'bg-yellow-900 text-yellow-200',
    '園芸': 'bg-emerald-900 text-emerald-200',
  };

  interface BookData {
    id: string;
    title: string;
    author: string;
    genre: string;
    asin: string | null;
    cover: string;
    tableOfContents: string[];
    excerpt: string;
  }

  function openModal(data: BookData) {
    modalCover.src = data.cover;
    modalCover.alt = data.title;

    modalGenre.textContent = data.genre;
    modalGenre.className = `text-xs px-2 py-0.5 rounded-full font-medium ${GENRE_COLOR[data.genre] ?? 'bg-gray-800 text-gray-300'}`;

    modalTitle.textContent = data.title;
    modalAuthor.textContent = data.author;

    // TOC
    modalToc.innerHTML = '';
    data.tableOfContents.forEach((chapter, i) => {
      const li = document.createElement('li');
      li.className = 'flex items-start gap-2 text-sm text-textMuted';
      li.innerHTML = `<span class="text-accent font-bold text-xs mt-0.5 w-4 flex-shrink-0">${i + 1}</span><span>${chapter}</span>`;
      modalToc.appendChild(li);
    });

    // Excerpt
    modalExcerpt.textContent = data.excerpt;

    // Amazon link
    if (data.asin) {
      modalAmazon.href = `https://www.amazon.co.jp/dp/${data.asin}?tag=honnotobira-22`;
      modalAmazon.style.display = '';
    } else {
      modalAmazon.style.display = 'none';
    }

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // Card click → open modal (skip when clicking Amazon link inside card)
  document.querySelectorAll<HTMLElement>('[data-book]').forEach((card) => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      const data: BookData = JSON.parse(card.dataset.book!);
      openModal(data);
    });
  });

  // Close triggers
  modalBackdrop.addEventListener('click', closeModal);
  modalClose.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
